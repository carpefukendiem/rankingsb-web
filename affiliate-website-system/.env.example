# API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Vercel Deployment
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=optional_team_id

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook_url
NOTIFICATION_PHONE=+1234567890

# Affiliate Tracking
BASE44_AFFILIATE_ID=your_base44_id
WIX_AFFILIATE_ID=your_wix_id
SQUARESPACE_AFFILIATE_ID=your_squarespace_id
GODADDY_AFFILIATE_ID=your_godaddy_id

# Optional: Proxies for scraping
PROXY_LIST=http://proxy1:port,http://proxy2:port

# Optional: OpenAI for reply analysis
OPENAI_API_KEY=your_openai_key
