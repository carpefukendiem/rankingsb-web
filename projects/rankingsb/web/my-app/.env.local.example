# Copy to `.env.local` (never commit secrets)

# --- Supabase (required for SyncLocal + admin auth) ---
# Project URL + anon key: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: same screen — server-only, never expose to the browser. Used by monthly verification cron.
SUPABASE_SERVICE_ROLE_KEY=

# --- SyncLocal cron security ---
# Vercel Cron will send: Authorization: Bearer <this value> when configured as CRON_SECRET in the Vercel project.
# You can also set SYNCLocal_CRON_VERIFY_SECRET and point the cron job at that value.
SYNCLocal_CRON_VERIFY_SECRET=
# CRON_SECRET=

# --- Google Business Profile (OAuth + resource) ---
# Create OAuth client (Desktop or Web) in Google Cloud Console, enable Business Profile APIs, run offline OAuth once to capture refresh token.
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_SECRET=
GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=
# Full location resource name, e.g. accounts/123456789/locations/987654321
GOOGLE_BUSINESS_PROFILE_LOCATION_RESOURCE=

# --- Bing Places ---
# API key / credential issued for your Microsoft listing integration.
BING_PLACES_API_KEY=
# Optional: override the HTTP endpoint SyncLocal posts to (defaults to a documented placeholder until your SKU is finalized).
# BING_PLACES_API_ENDPOINT=

# --- Facebook Business (Graph API) ---
# Page access token with permissions to update business page fields you need.
FACEBOOK_GRAPH_API_TOKEN=
# Numeric Facebook Page ID for the business storefront.
FACEBOOK_BUSINESS_PAGE_ID=

# --- Alerts (optional) ---
# WHERE monthly verification summaries should go once email is wired (see lib/synclocal/email.ts).
# SYNCLocal_ALERT_EMAIL=ruben@rankingsb.com

# --- Other production secrets ---
# Add your existing deployment keys in `.env.local` as needed (do not commit).
