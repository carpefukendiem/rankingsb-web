{
  "version": 2,
  "name": "rankingsb-web",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://rankingsb.com"
  },
  "github": {
    "enabled": true,
    "autoAlias": true,
    "silent": false
  },
  "redirects": [
    { "source": "/local-marketing-services", "destination": "/services", "permanent": true },
    { "source": "/markeing-services",         "destination": "/services", "permanent": true },
    { "source": "/local-business-websites",   "destination": "/services/website-design", "permanent": true },
    { "source": "/local-lead-machine",        "destination": "/services/local-seo", "permanent": true },
    { "source": "/contactus",                 "destination": "/contact", "permanent": true },
    { "source": "/book-your-call",            "destination": "/free-audit", "permanent": true },
    { "source": "/booking-appointment",       "destination": "/free-audit", "permanent": true },
    { "source": "/pricing",                   "destination": "/pricing", "permanent": false },
    { "source": "/tos",                       "destination": "/", "permanent": true },
    { "source": "/privacy-policy-7297",       "destination": "/", "permanent": true },
    { "source": "/home-4380",                 "destination": "/", "permanent": true },
    { "source": "/undefined",                 "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
